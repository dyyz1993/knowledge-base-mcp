# Knowledge Base MCP 配置
# 复制此文件为 .env 并按需修改

# === 基础配置 ===

# 数据存储目录（默认 ~/.knowledge）
# KB_DIR=/path/to/data

# HTTP 端口（默认 19877）
# PORT=19877

# API 密钥（生产环境必须设置，启用 Bearer token 认证）
# KB_API_KEY=your-secret-key

# === 代理配置 ===

# HTTP/HTTPS 代理（用于网络请求）
# http_proxy=http://127.0.0.1:7890
# https_proxy=http://127.0.0.1:7890
# all_proxy=socks5://127.0.0.1:7890

# === 日志配置 ===

# 日志级别：debug/info/warn/error（默认 info）
# LOG_LEVEL=info

# 日志格式：json/pretty（默认 pretty）
# LOG_FORMAT=pretty

# === 功能开关 ===

# 禁用 LLM 调用（仅使用本地搜索，不调用远程模型）
# KB_NO_LLM=1
